import streamlit as st

from showcase_simulation import ShowcaseConfig, predict_patient, run_showcase_simulation
from utils import format_percent, format_seconds, load_heart_disease_dataset


st.set_page_config(
    page_title="GA Heart Disease Showcase",
    layout="wide",
    initial_sidebar_state="expanded",
)


CSS = """
<style>
@import url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700&family=Inter:wght@400;500;600&display=swap');

